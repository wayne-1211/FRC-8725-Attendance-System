{
  "name": "Team 8725 Attendance System",
  "short_name": "Team 8725",
  "description": "Misty Panther · Workshop 點名系統（NFC 學生證 + Firebase）",
  "id": "./",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "any",
  "background_color": "#121212",
  "theme_color": "#121212",
  "lang": "zh-Hant",
