      "url": "./#/scan",
      "icons": [{ "src": "images/icons/nfc.svg", "sizes": "any", "type": "image/svg+xml" }]
    },
    {
      "name": "資料匯總",
      "short_name": "匯總",
      "description": "查看場次、出席名單與統計",
